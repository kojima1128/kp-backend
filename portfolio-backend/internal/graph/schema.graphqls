type Query {
  user(id: ID!): User
  users: [User!]!
}

type Mutation {
  createUser(input: CreateUserInput!): User!
}

type User {
  id: ID!
  cognitoId: String!
  name: String!
  tenantId: String!
  siteId: String!
  role: String!
  email: String!
  createdAt: String!
  updatedAt: String!
}

input CreateUserInput {
  cognitoId: String!
  name: String!
  tenantId: String!
  siteId: String!
  role: String
  email: String!
}
